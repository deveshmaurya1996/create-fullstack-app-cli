<h1>Sign in</h1>
<form (ngSubmit)="submit()">
  <div style="display: flex; flex-direction: column; gap: 0.75rem; max-width: 20rem;">
    <label>
      Email
      <input
        name="email"
        [(ngModel)]="email"
        type="email"
        autocomplete="username"
        style="display: block; width: 100%; margin-top: 0.25rem;"
      />
    </label>
    <label>
      Password
      <input
        name="password"
        [(ngModel)]="password"
        type="password"
        autocomplete="current-password"
        style="display: block; width: 100%; margin-top: 0.25rem;"
      />
    </label>
    <button type="submit">Sign in</button>
  </div>
</form>
@if (error) {
  <p role="alert" style="color: crimson; margin-top: 1rem;">\{{ error }}</p>
}
