import { Router } from 'express';
import { uploadToS3 } from '../services/s3.service';

export const s3UploadRouter = Router();

s3UploadRouter.post('/upload/s3', async (req, res, next) => {
  try {
    const { key, contentBase64, contentType } = req.body as {
      key: string;
      contentBase64: string;
      contentType?: string;
    };
    await uploadToS3({
      key,
      buffer: Buffer.from(contentBase64, 'base64'),
      contentType,
    });
    res.json({ ok: true });
  } catch (error) {
    next(error);
  }
});
