import { Hono } from 'hono';

const users = [{ id: '1', email: 'demo@example.com' }];

export const usersRoute = new Hono()
  .get('/', (c) => c.json(users))
  .get('/:id', (c) => {
    const user = users.find((u) => u.id === c.req.param('id'));
    if (!user) return c.json({ message: 'User not found' }, 404);
    return c.json(user);
  });
