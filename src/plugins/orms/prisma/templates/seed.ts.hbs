import { prisma } from '../src/lib/db.js';

async function main() {
  await prisma.user.create({
    data: {
      email: 'hello@example.com',
      name: 'Example User',
    },
  });
}

main()
  .then(() => prisma.$disconnect())
  .catch(async (e) => {
    console.error(e);
    await prisma.$disconnect();
    process.exit(1);
  });
