generator client {
  provider = "prisma-client-js"
}

datasource db {
{{#if hasPostgres}}
  provider = "postgresql"
{{else if hasMysql}}
  provider = "mysql"
{{else}}
  provider = "sqlite"
{{/if}}
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
